{
	"compilerOptions": {
		"declaration": true,
		"emitDecoratorMetadata": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"lib": ["ES2022", "DOM"],
		"module": "CommonJS",
		"moduleResolution": "node",
		"outDir": "./dist/",
		"preserveConstEnums": true,
		"resolveJsonModule": true,
		"rootDir": "./src",
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"strictPropertyInitialization": false,
		"target": "es2022"
	},
	"exclude": ["node_modules", "dist"]
}
