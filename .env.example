# Service identity
SERVICE_NAME=feature-service
NODE_ENV=development

# Express health-check server (separate port from event-service)
EXPRESS_HOST=0.0.0.0
EXPRESS_PORT=3002

# Logging
LOG_LEVEL=INFO

# Odin / Zookeeper (only required in staging / production)
ODIN_ROOT_CONFIG_PATH=/zookeeper/system/aap
ZK_CONFIG_MAX_RETRIES=3
ZK_CONFIG_PROMISE_TIMEOUT=10000
ZK_CONFIG_TIMEOUT_INTERVAL=10000
ZK_CONFIG_CONNECTION_STRING=

# Kafka — feature-service consumes the SAME topics as event-service but with
# a separate consumer group, so both services receive every event independently.
# Local dev  : localhost:9092  (KAFKA_AUTH_TYPE=none, docker-compose)
# Production : MSK IAM brokers on port 9098  (KAFKA_AUTH_TYPE=iam)
KAFKA_BROKERS=b-1.analytics-msk.xxxxx.c2.kafka.ap-south-1.amazonaws.com:9098,b-2.analytics-msk.xxxxx.c2.kafka.ap-south-1.amazonaws.com:9098,b-3.analytics-msk.xxxxx.c2.kafka.ap-south-1.amazonaws.com:9098
KAFKA_AUTH_TYPE=iam
#
# BUSINESS_TOPICS MUST stay in sync with ingestion-service / event-service.
# Format: "<business>:<topic>,<business>:<topic>,...".
# Format: "<brand>:<topic>"
# Each deployed instance should subscribe to exactly ONE brand's topic and
# set CONSUMER_GROUP_ID to the matching brand group (see below).
BUSINESS_TOPICS=aap:events_aap,gemsmantra:events_gemsmantra,horocosmo:events_horocosmo
DLQ_TOPIC=features_dlq
# Set to the brand this instance owns: feature-service.builder.aap | feature-service.builder.gemsmantra | feature-service.builder.horocosmo
CONSUMER_GROUP_ID=feature-service.builder.aap
PARTITIONS_CONCURRENCY=8
MAX_IN_FLIGHT=200
HEARTBEAT_INTERVAL_MS=5000

# MongoDB — destination for the per-user feature store
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=features
MONGO_USER=
MONGO_PASSWORD=
MONGO_COLLECTION=user_features
# Pool sizing — tune to (peak partitions consumed concurrently × per-partition fanout)
MONGO_MIN_POOL=5
MONGO_MAX_POOL=100

# Idempotency cache (Redis). Required to make $inc/$max upserts safe under
# Kafka redelivery. Set IDEMPOTENCY_ENABLED=false only in dev / replays.
IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_TTL_SECONDS=86400

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Sentry / NewRelic (only required in production)
SENTRY_DSN=
NEW_RELIC_APP_NAME=feature-service
NEW_RELIC_LICENSE_KEY=
