{
	"name": "feature-service",
	"version": "1.0.0",
	"main": "src/bin/consumer.bin.ts",
	"description": "Kafka consumer that builds per-user feature documents in MongoDB from ingestion-service / backend events.",
	"author": "harsh-aap",
	"license": "ISC",
	"scripts": {
		"build": "rm -rf ./dist && npx tsc",
		"start": "NODE_ENV=development node -r ts-node/register --env-file=.env ./src/bin/consumer.bin.ts",
		"dev": "nodemon --config nodemon.consumer.json",
		"lint": "eslint . --fix && npx tsc --noEmit",
		"ri": "echo 'reinstalling tst-base' && yarn upgrade tst-base && yarn install",
		"postinstall": "cd node_modules/tst-base && tsc --strict false || true"
	},
	"dependencies": {
		"ajv": "^8.17.1",
		"ajv-formats": "^3.0.1",
		"body-parser": "^1.20.3",
		"express": "^4.19.2",
		"inversify": "^6.0.2",
		"ioredis": "^5.4.1",
		"lodash": "^4.17.21",
		"morgan": "^1.10.0",
		"newrelic": "^12.3.0",
		"reflect-metadata": "^0.2.2",
		"tst-base": "file:./base"
	},
	"devDependencies": {
		"@types/body-parser": "^1.19.5",
		"@types/express": "^4.17.21",
		"@types/lodash": "^4.17.7",
		"@types/morgan": "^1.9.9",
		"@types/newrelic": "^9.14.4",
		"@types/node": "^20.14.9",
		"@typescript-eslint/eslint-plugin": "^7.13.1",
		"@typescript-eslint/parser": "^7.16.0",
		"eslint": "^8.57.0",
		"eslint-config-airbnb-base": "^15.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.29.1",
		"eslint-plugin-prettier": "^5.2.1",
		"eslint-plugin-unused-imports": "^3.2.0",
		"nodemon": "^3.1.4",
		"prettier": "^3.3.3",
		"ts-node": "^10.9.2",
		"typescript": "^5.5.4"
	},
	"packageManager": "yarn@1.22.22"
}
