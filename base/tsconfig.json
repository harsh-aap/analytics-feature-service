{
	"compilerOptions": {
		"target": "es2022",
		"module": "CommonJS",
		"moduleResolution": "node",
		"declaration": true,
		"preserveConstEnums": true,
		"sourceMap": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"strict": true,
		"strictPropertyInitialization": false,
		"skipLibCheck": true,
		"resolveJsonModule": false, // rule  no import json in base module
		"esModuleInterop": true
	},
	"exclude": ["node_modules", "dist", "./src/examples", "**/example.ts"]
}
